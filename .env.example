# Local laptop / analysis mode
ORLIK_APP_MODE=local-analysis

# local-db imports into this machine's SQLite.
# remote-api posts match_package.json to the production server.
ORLIK_PUBLISH_TARGET=local-db

# Used only when ORLIK_PUBLISH_TARGET=remote-api on the local analysis machine.
ORLIK_PRODUCTION_API_URL=https://your-production-domain.example
ORLIK_PRODUCTION_API_TOKEN=change-me

# Used by the production server to protect POST /api/admin/import-match.
# Leave empty only for local development.
ORLIK_ADMIN_IMPORT_TOKEN=change-me

ORLIK_DATABASE_PATH=/app/storage/database/orlik.sqlite3
ORLIK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ORLIK_DEFAULT_PITCH_WIDTH_M=30
ORLIK_DEFAULT_PITCH_LENGTH_M=47.4

# Vite variables are public in the browser. Do not put secrets in VITE_*.
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_MODE=local-analysis

BACKEND_PORT=8000
CLIENT_PORT=5173
